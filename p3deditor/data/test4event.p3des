# P3DE v0.5.0 Interactive Test Script
# This script is designed to be mounted to any entity using 'mount'
# Example: mount Cube_0 onClick v0.5.0_test.p3des

echo "[$this] Event triggered! Executing interaction logic..."

# Execute a simple jumping animation
move $this 0 -50 0
wait 200
move $this 0 50 0
wait 200
move $this 0 -30 0
wait 150
move $this 0 30 0

echo "[$this] Interaction complete. Click STOP to reset scene."
